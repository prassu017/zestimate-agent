# ───────────────────────────────────────────────────────────────
# Zestimate Agent — environment configuration
# Copy to `.env` and fill in your keys.
# ───────────────────────────────────────────────────────────────

# ─── Fetcher ────────────────────────────────────────────────────
# Which fetcher to use as primary. One of: unblocker | playwright
FETCHER_PRIMARY=unblocker

# Unblocker provider. One of: zenrows | scraperapi | brightdata
UNBLOCKER_PROVIDER=zenrows
UNBLOCKER_API_KEY=

# Playwright fallback settings (only used if FETCHER_PRIMARY=playwright
# or if the primary fetcher fails and fallback is enabled)
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_PROXY_URL=   # optional residential proxy (http://user:pass@host:port)

# ─── Address normalization (optional upgrade) ───────────────────
# If set, ambiguous addresses fall back to Google Geocoding.
GOOGLE_GEOCODING_API_KEY=

# ─── Cross-check / sanity validation ────────────────────────────
# One of: none | rentcast | attom
CROSSCHECK_PROVIDER=none
CROSSCHECK_API_KEY=

# Max allowed percentage difference before flagging cross-check mismatch
CROSSCHECK_TOLERANCE_PCT=10.0

# Master switch — set to 0/false to disable all cross-checking globally.
CROSSCHECK_ENABLED=true

# ─── Rentcast budget guardrails ─────────────────────────────────
# Hard monthly cap on Rentcast API calls. Free tier is ~50/mo; we cap at
# 40 to leave headroom for debugging and eval runs. When this cap is hit,
# cross-check is silently skipped — it never blocks a Zestimate lookup.
RENTCAST_MONTHLY_CAP=40
RENTCAST_USAGE_PATH=.cache/rentcast_usage.json
# Set to 1 to allow exceeding the cap (sticky). Also controllable per-call
# via `zestimate lookup --force-crosscheck ...`.
RENTCAST_ALLOW_OVERAGE=false

# ─── Cache ──────────────────────────────────────────────────────
# One of: sqlite | memory | none
CACHE_BACKEND=sqlite
CACHE_PATH=.cache/zestimate.db
CACHE_TTL_SECONDS=21600   # 6 hours

# ─── HTTP / retries ─────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE_SECONDS=1.5

# ─── Observability ──────────────────────────────────────────────
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=pretty     # pretty | json

# ─── API server (optional) ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
